//Advent of Code 2015 Day 1. Nested paraentheses.

//My first idea - filter and count

//Ben's idea. Map it to -1, 1, then sum
void main(){
	import std.range;
	import std.algorithm;
	import std.stdio;
	
	writeln(input.map!(x => x == '(' ? 1 : -1).sum());

	writeln(input.map!( x => x == '(' ? 1 : -1)
		.cumulativeFold!((x, y) => x + y)(0) //0 is the seed value
		.countUntil!(x => x < 0) + 1);
}

